#!/usr/bin/env bash
# .git/hooks/pre-commit — mirrors every step of the CI pipeline.
# Install: make install-hooks   (or: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit)
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # no colour

step() { echo -e "\n${YELLOW}▶ $*${NC}"; }
ok()   { echo -e "${GREEN}✓ $*${NC}"; }
fail() { echo -e "${RED}✗ $*${NC}"; exit 1; }

# ── Format ────────────────────────────────────────────────────────────────────
step "Checking formatting (gofmt)"
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
  echo "The following files need formatting (run 'go fmt ./...'):"
  echo "$unformatted"
  fail "Format check failed"
fi
ok "Format check passed"

# ── Lint ──────────────────────────────────────────────────────────────────────
step "Running golangci-lint"
if ! command -v golangci-lint &>/dev/null; then
  echo "golangci-lint not found — skipping lint (install with: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest)"
else
  golangci-lint run ./... || fail "Lint check failed"
  ok "Lint check passed"
fi

# ── Build ─────────────────────────────────────────────────────────────────────
step "Building"
go build -o gocker . || fail "Build failed"
ok "Build passed"

# ── Unit tests ────────────────────────────────────────────────────────────────
step "Running unit tests"
go test ./internal/... -count=1 || fail "Unit tests failed"
ok "Unit tests passed"

# ── Integration tests ─────────────────────────────────────────────────────────
step "Running integration tests"
go test ./tests/integration/... -count=1 || fail "Integration tests failed"
ok "Integration tests passed"

echo -e "\n${GREEN}All checks passed — committing.${NC}"
